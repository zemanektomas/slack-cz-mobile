{
  "expo": {
    "name": "Slackline CZ",
    "slug": "slackline-cz",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "slacklinecz",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.slackline.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "cz.slackline.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@maplibre/maplibre-react-native",
        {
          "net": "open-source"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Slackline CZ potřebuje polohu pro zobrazení tvého místa na mapě."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}

{
  "expo": {
    "name": "Slackline.Ova",
    "slug": "slackline-ova",
    "version": "0.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "slacklineova",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.slackline.ova"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "cz.slackline.ova"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@maplibre/maplibre-react-native",
        {
          "net": "open-source"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Slackline.Ova potřebuje polohu pro zobrazení tvého místa na mapě."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
